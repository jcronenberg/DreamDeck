code = "shader_type spatial;
render_mode blend_mix, depth_draw_always, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D tex_frg_9;
uniform sampler2D tex_frg_12;
uniform sampler2D tex_frg_11;
uniform sampler2D tex_frg_17;



void fragment() {
// Texture2D:9
	vec4 n_out9p0 = texture(tex_frg_9, UV);


// Texture2D:12
	vec4 n_out12p0 = texture(tex_frg_12, UV);


// FloatOp:16
	float n_in16p1 = 0.05000;
	float n_out16p0 = n_out12p0.x * n_in16p1;


// Texture2D:11
	vec4 n_out11p0 = texture(tex_frg_11, UV);


// VectorOp:15
	vec4 n_out15p0 = vec4(n_out16p0) + n_out11p0;


// Texture2D:17
	vec4 n_out17p0 = texture(tex_frg_17, UV);


// FloatOp:19
	float n_in19p1 = 0.40000;
	float n_out19p0 = n_out17p0.x * n_in19p1;


// VectorOp:18
	vec4 n_out18p0 = n_out15p0 + vec4(n_out19p0);


// ColorConstant:10
	vec4 n_out10p0 = vec4(1.000000, 1.000000, 1.000000, 1.000000);


// Output:0
	ALPHA = n_out9p0.x;
	EMISSION = vec3(n_out18p0.xyz);
	BACKLIGHT = vec3(n_out10p0.xyz);


}
"
